# Render environment variables for scheduling-software-
# Copy these into Render -> Service -> Environment
# Do NOT commit real secrets.

# Render sets this automatically in production.
# PORT=10000

# Required for token encryption (recommended)
APP_SECRET_KEY=replace_with_long_random_secret_32_plus_chars

# Google Calendar OAuth (set these only if using Google integration)
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=https://YOUR-RENDER-SERVICE.onrender.com/api/google-calendar/callback

# QuickBooks OAuth (set these only if using QuickBooks integration)
QUICKBOOKS_CLIENT_ID=your_quickbooks_client_id
QUICKBOOKS_CLIENT_SECRET=your_quickbooks_client_secret
QUICKBOOKS_REDIRECT_URI=https://YOUR-RENDER-SERVICE.onrender.com/api/quickbooks/callback

# QuickBooks webhook security (optional, recommended if webhook enabled)
QUICKBOOKS_VERIFIER_TOKEN=replace_with_webhook_verifier_token

# Optional override (production default shown)
QUICKBOOKS_API_BASE_URL=https://quickbooks.api.intuit.com

# PostgreSQL (Render managed database)
PGHOST=dpg-d7l7mofavr4c73c44m7g-a
PGPORT=5432
PGDATABASE=scheduling_server
PGUSER=scheduling_server_user
PGPASSWORD=P5cyy5ntsODOLTZg0iOoOdI3lzNcg2Zt

# Preferred single-connection string (if your app uses DATABASE_URL)
DATABASE_URL=postgresql://scheduling_server_user:P5cyy5ntsODOLTZg0iOoOdI3lzNcg2Zt@dpg-d7l7mofavr4c73c44m7g-a/scheduling_server

# External connection string (for local tools like psql)
EXTERNAL_DATABASE_URL=postgresql://scheduling_server_user:P5cyy5ntsODOLTZg0iOoOdI3lzNcg2Zt@dpg-d7l7mofavr4c73c44m7g-a.oregon-postgres.render.com/scheduling_server
